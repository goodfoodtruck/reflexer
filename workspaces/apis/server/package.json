{
  "name": "@reflexer/server",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "dev": "pnpm --filter @reflexer/engine build && pnpm exec ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "seed": "pnpm exec tsx src/seed.ts",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@reflexer/engine": "workspace:*",
    "@types/morgan": "^1.9.10",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.8.9",
    "morgan": "^1.11.0",
    "tsup": "^8.5.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0"
  }
}
